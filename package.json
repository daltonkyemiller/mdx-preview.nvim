{
  "name": "mdx-preview.nvim",
  "private": true,
  "bin": {
    "mdx-preview": "./bin/mdx-preview.mjs"
  },
  "type": "module",
  "scripts": {
    "build": "node bin/mdx-preview.mjs build",
    "check": "node --check server/server.mjs && node --check server/runtime.mjs && node --check server/build.mjs && node --check server/publish.mjs && node --check bin/mdx-preview.mjs",
    "format": "oxfmt --config oxfmt.json --write .",
    "format:check": "oxfmt --config oxfmt.json --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "mdx-preview": "node bin/mdx-preview.mjs",
    "test:neovim": "nvim --headless -u NONE -l test/neovim-smoke.lua",
    "preview": "node bin/mdx-preview.mjs serve",
    "start": "node server/server.mjs",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-react": "^5.0.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.18",
    "vite": "^7.1.7"
  },
  "devDependencies": {
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "packageManager": "pnpm@11.8.0"
}
