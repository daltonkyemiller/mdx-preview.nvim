{
  "name": "mdx-preview.nvim",
  "private": true,
  "bin": {
    "mdx-preview": "./bin/mdx-preview.mjs"
  },
  "type": "module",
  "scripts": {
    "build": "node bin/mdx-preview.mjs build",
    "check": "for file in server/*.mjs bin/mdx-preview.mjs; do node --check \"$file\"; done",
    "format": "oxfmt --config oxfmt.json --write .",
    "format:check": "oxfmt --config oxfmt.json --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "mdx-preview": "node bin/mdx-preview.mjs",
    "test:neovim": "nvim --headless -u NONE -l test/neovim-smoke.lua",
    "preview": "node bin/mdx-preview.mjs serve",
    "start": "node server/server.mjs",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dagrejs/dagre": "^3.0.0",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-react": "^5.0.2",
    "@xyflow/react": "^12.11.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "vite": "^7.1.7"
  },
  "devDependencies": {
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "packageManager": "pnpm@11.8.0"
}
